# Frontend environment variables
# Copy this file to .env.local and fill in the values for your environment.
#
# VITE_CODESPACE_NAME is required when running inside a GitHub Codespace
# so the frontend knows the correct backend URL:
#   https://<VITE_CODESPACE_NAME>-8000.app.github.dev
#
# Find your codespace name in the browser URL, e.g.:
#   https://my-handle-my-repo-abc123-5173.app.github.dev
#                ^^^^^^^^^^^^^^^^^^^^^^ <- this is your CODESPACE_NAME
#
# Example:
#   VITE_CODESPACE_NAME=my-handle-my-repo-abc123
VITE_CODESPACE_NAME=

# Optional: override the entire API base URL (useful for local dev against a
# non-standard host/port).
# VITE_API_BASE_URL=http://localhost:8000
